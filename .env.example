# ─────────────────────────────────────────────────────────────────
# Gekko — Environment Variables
# Copy to .env and fill in values before running npm start
# Run `npm run setup` to generate agent keypairs and build the
# ERC-7710 delegation chain automatically.
# ─────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────
NETWORK_NAME=base-sepolia
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# MetaMask Delegation Toolkit implementation address (ERC-7710)
DELEGATION_IMPL=0x0000000000000000000000000000000000000000

# ── Agent EOA Keypairs (generated by setup.js — do not hand-edit) ─
ORCHESTRATOR_PRIVATE_KEY=0x
ORCHESTRATOR_ADDRESS=0x
RESEARCHER_PRIVATE_KEY=0x
RESEARCHER_ADDRESS=0x
WRITER_PRIVATE_KEY=0x
WRITER_ADDRESS=0x
# Validator shares researcher keypair
VALIDATOR_PRIVATE_KEY=
VALIDATOR_ADDRESS=

# ── 1Shot Relayer ────────────────────────────────────────────────
# Get your key at https://1shot.io
ONESHOT_API_KEY=
ONESHOT_BASE_URL=https://1shot.io
ONESHOT_WEBHOOK_SECRET=

# ── Venice AI ────────────────────────────────────────────────────
# Get your key at https://venice.ai
VENICE_API_KEY=

# ── x402 Micropayments ───────────────────────────────────────────
# Base URL where the backend is reachable (for x402 payment routing)
X402_ENDPOINT_BASE=http://localhost:3001
# Address that receives x402 micropayments (can be orchestrator address)
X402_TREASURY_ADDRESS=0x

# ── Server ───────────────────────────────────────────────────────
PORT=3001
DEPLOYED_URL=
DISPATCH_API_KEY=
